# Copy to .env and fill in your API keys.
# Get OpenRouter key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Web search (used by chat when toggled on)
BRAVE_API_KEY=
TAVILY_API_KEY=
SEARCH_PROVIDER=auto

# Model routing (defaults are fine; override if needed)
# MODEL_FAST=deepseek/deepseek-v3.2
# MODEL_BALANCED=google/gemini-2.5-flash
# MODEL_POWERFUL=google/gemini-3.1-pro-preview   ← used by metadata_inferrer
